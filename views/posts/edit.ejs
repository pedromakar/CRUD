<h1>Editar post</h1>

<form action="/posts/<%= post.id %>?_method=PUT" method="POST">
    <div class="form-group">
        <label for="title">Título</label>
        <input type="text" class="form-control" id="title" name="title" value="<%= post.title %>" required>
    </div>
    <div class="form-group">
        <label for="content">Conteúdo</label>
        <textarea class="form-control" id="content" name="content" rows="10" required><%= post.content %></textarea>
    </div>
    <div class="form-group">
        <label for="category">Categoria</label>
        <select class="form-control" id="category" name="category" required>
            <% categorias.forEach(function(categoria) { %>
                <option value="<%= categoria.id %>" <%= post.category == categoria.id ? 'selected' : '' %>><%= categoria.nome %></option>
            <% }); %>
        </select>
    </div>
    <button type="submit" class="btn btn-warning">Salvar</button>